<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:bioc="http://bpmn.io/schema/bpmn/biocolor/1.0" xmlns:color="http://www.omg.org/spec/BPMN/non-normative/color/1.0" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_ToBeMenuPlanningAI" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.35.0" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.6.0">
  <bpmn:collaboration id="Collaboration_ToBeMenuPlanningAI">
    <bpmn:participant id="Participant_ToBeMenuPlanningAI" name="Proses Menu Planning TO BE (AI-Driven)" processRef="Process_ToBeMenuPlanningAI" />
  </bpmn:collaboration>

  <bpmn:process id="Process_ToBeMenuPlanningAI" isExecutable="true">
    <bpmn:laneSet id="LaneSet_ToBeMenuPlanningAI">
      <bpmn:lane id="Lane_PengawasGizi" name="Pengawas Gizi">
        <bpmn:flowNodeRef>Event_Start</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_InputDraft</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_UploadLampiran</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_RevisiMenu</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_FinalValidation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_FinalApproval</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_SistemMenuAI" name="Sistem Menu Planning &amp; AI">
        <bpmn:flowNodeRef>Activity_SaveDraft</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ParallelSplit</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_AINutritionAnalysis</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ParallelJoin</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_StockAndAI</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_HppCheck</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_CostCheck</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_PublishMenu</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_SendProductionPlan</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_ReceiveScheduleConfirm</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_KoordinatorSCM" name="Koordinator Tim Bahan Makanan">
        <bpmn:flowNodeRef>Activity_CheckStock</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_ReceiveStockStatus</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Finance" name="Finance Manager">
        <bpmn:flowNodeRef>Activity_FinanceReview</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_CostApproved</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_RevisiBiaya</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_SupervisorProduksi" name="Supervisor Produksi">
        <bpmn:flowNodeRef>Activity_LockWeeklyPlan</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_End</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="Event_Start" name="Permintaan penyusunan menu">
      <bpmn:outgoing>Flow_01</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:userTask id="Activity_InputDraft" name="Input draft menu dan target gizi">
      <bpmn:incoming>Flow_01</bpmn:incoming>
      <bpmn:outgoing>Flow_02</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:manualTask id="Activity_UploadLampiran" name="Unggah gambar dan lampiran resep">
      <bpmn:incoming>Flow_02</bpmn:incoming>
      <bpmn:outgoing>Flow_03</bpmn:outgoing>
    </bpmn:manualTask>

    <bpmn:serviceTask id="Activity_SaveDraft" name="Simpan draft menu ke repository">
      <bpmn:incoming>Flow_03</bpmn:incoming>
      <bpmn:incoming>Flow_13</bpmn:incoming>
      <bpmn:incoming>Flow_20</bpmn:incoming>
      <bpmn:outgoing>Flow_04</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:parallelGateway id="Gateway_ParallelSplit" name="Analisis paralel">
      <bpmn:incoming>Flow_04</bpmn:incoming>
      <bpmn:outgoing>Flow_05</bpmn:outgoing>
      <bpmn:outgoing>Flow_06</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:serviceTask id="Activity_AINutritionAnalysis" name="Jalankan analisis gizi AI">
      <bpmn:incoming>Flow_05</bpmn:incoming>
      <bpmn:outgoing>Flow_07</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:sendTask id="Activity_CheckStock" name="Kirim permintaan cek stok ke SCM">
      <bpmn:incoming>Flow_06</bpmn:incoming>
      <bpmn:outgoing>Flow_08</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:receiveTask id="Activity_ReceiveStockStatus" name="Terima konfirmasi stok bahan">
      <bpmn:incoming>Flow_08</bpmn:incoming>
      <bpmn:outgoing>Flow_09</bpmn:outgoing>
    </bpmn:receiveTask>

    <bpmn:parallelGateway id="Gateway_ParallelJoin" name="Gabungkan hasil AI dan stok">
      <bpmn:incoming>Flow_07</bpmn:incoming>
      <bpmn:incoming>Flow_09</bpmn:incoming>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
    </bpmn:parallelGateway>

    <bpmn:exclusiveGateway id="Gateway_StockAndAI" name="Stok dan gizi memenuhi syarat?">
      <bpmn:incoming>Flow_10</bpmn:incoming>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
      <bpmn:outgoing>Flow_12</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:manualTask id="Activity_RevisiMenu" name="Revisi komposisi menu">
      <bpmn:incoming>Flow_12</bpmn:incoming>
      <bpmn:incoming>Flow_22</bpmn:incoming>
      <bpmn:outgoing>Flow_13</bpmn:outgoing>
    </bpmn:manualTask>

    <bpmn:serviceTask id="Activity_HppCheck" name="Hitung HPP dan cek anggaran">
      <bpmn:incoming>Flow_11</bpmn:incoming>
      <bpmn:outgoing>Flow_14</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:exclusiveGateway id="Gateway_CostCheck" name="HPP sesuai budget?">
      <bpmn:incoming>Flow_14</bpmn:incoming>
      <bpmn:outgoing>Flow_15</bpmn:outgoing>
      <bpmn:outgoing>Flow_16</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="Activity_FinanceReview" name="Review biaya dan anggaran">
      <bpmn:incoming>Flow_16</bpmn:incoming>
      <bpmn:outgoing>Flow_17</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="Gateway_CostApproved" name="Disetujui finance?">
      <bpmn:incoming>Flow_17</bpmn:incoming>
      <bpmn:outgoing>Flow_18</bpmn:outgoing>
      <bpmn:outgoing>Flow_19</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:manualTask id="Activity_RevisiBiaya" name="Revisi bahan atau porsi">
      <bpmn:incoming>Flow_19</bpmn:incoming>
      <bpmn:outgoing>Flow_20</bpmn:outgoing>
    </bpmn:manualTask>

    <bpmn:userTask id="Activity_FinalValidation" name="Validasi final menu">
      <bpmn:incoming>Flow_15</bpmn:incoming>
      <bpmn:incoming>Flow_18</bpmn:incoming>
      <bpmn:outgoing>Flow_21</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="Gateway_FinalApproval" name="Menu disetujui?">
      <bpmn:incoming>Flow_21</bpmn:incoming>
      <bpmn:outgoing>Flow_22</bpmn:outgoing>
      <bpmn:outgoing>Flow_23</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:serviceTask id="Activity_PublishMenu" name="Aktifkan menu dan simpan hasil analisis">
      <bpmn:incoming>Flow_23</bpmn:incoming>
      <bpmn:outgoing>Flow_24</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:sendTask id="Activity_SendProductionPlan" name="Kirim menu aktif ke modul produksi dan weekly plan">
      <bpmn:incoming>Flow_24</bpmn:incoming>
      <bpmn:outgoing>Flow_25</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:receiveTask id="Activity_ReceiveScheduleConfirm" name="Terima konfirmasi jadwal produksi">
      <bpmn:incoming>Flow_25</bpmn:incoming>
      <bpmn:outgoing>Flow_26</bpmn:outgoing>
    </bpmn:receiveTask>

    <bpmn:manualTask id="Activity_LockWeeklyPlan" name="Kunci weekly plan dan arsipkan versi menu">
      <bpmn:incoming>Flow_26</bpmn:incoming>
      <bpmn:outgoing>Flow_27</bpmn:outgoing>
    </bpmn:manualTask>

    <bpmn:endEvent id="Event_End">
      <bpmn:incoming>Flow_27</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_01" sourceRef="Event_Start" targetRef="Activity_InputDraft" />
    <bpmn:sequenceFlow id="Flow_02" sourceRef="Activity_InputDraft" targetRef="Activity_UploadLampiran" />
    <bpmn:sequenceFlow id="Flow_03" sourceRef="Activity_UploadLampiran" targetRef="Activity_SaveDraft" />
    <bpmn:sequenceFlow id="Flow_04" sourceRef="Activity_SaveDraft" targetRef="Gateway_ParallelSplit" />
    <bpmn:sequenceFlow id="Flow_05" sourceRef="Gateway_ParallelSplit" targetRef="Activity_AINutritionAnalysis" />
    <bpmn:sequenceFlow id="Flow_06" sourceRef="Gateway_ParallelSplit" targetRef="Activity_CheckStock" />
    <bpmn:sequenceFlow id="Flow_07" sourceRef="Activity_AINutritionAnalysis" targetRef="Gateway_ParallelJoin" />
    <bpmn:sequenceFlow id="Flow_08" sourceRef="Activity_CheckStock" targetRef="Activity_ReceiveStockStatus" />
    <bpmn:sequenceFlow id="Flow_09" sourceRef="Activity_ReceiveStockStatus" targetRef="Gateway_ParallelJoin" />
    <bpmn:sequenceFlow id="Flow_10" sourceRef="Gateway_ParallelJoin" targetRef="Gateway_StockAndAI" />
    <bpmn:sequenceFlow id="Flow_11" name="Ya" sourceRef="Gateway_StockAndAI" targetRef="Activity_HppCheck" />
    <bpmn:sequenceFlow id="Flow_12" name="Tidak" sourceRef="Gateway_StockAndAI" targetRef="Activity_RevisiMenu" />
    <bpmn:sequenceFlow id="Flow_13" sourceRef="Activity_RevisiMenu" targetRef="Activity_SaveDraft" />
    <bpmn:sequenceFlow id="Flow_14" sourceRef="Activity_HppCheck" targetRef="Gateway_CostCheck" />
    <bpmn:sequenceFlow id="Flow_15" name="Ya" sourceRef="Gateway_CostCheck" targetRef="Activity_FinalValidation" />
    <bpmn:sequenceFlow id="Flow_16" name="Tidak" sourceRef="Gateway_CostCheck" targetRef="Activity_FinanceReview" />
    <bpmn:sequenceFlow id="Flow_17" sourceRef="Activity_FinanceReview" targetRef="Gateway_CostApproved" />
    <bpmn:sequenceFlow id="Flow_18" name="Ya" sourceRef="Gateway_CostApproved" targetRef="Activity_FinalValidation" />
    <bpmn:sequenceFlow id="Flow_19" name="Tidak" sourceRef="Gateway_CostApproved" targetRef="Activity_RevisiBiaya" />
    <bpmn:sequenceFlow id="Flow_20" sourceRef="Activity_RevisiBiaya" targetRef="Activity_SaveDraft" />
    <bpmn:sequenceFlow id="Flow_21" sourceRef="Activity_FinalValidation" targetRef="Gateway_FinalApproval" />
    <bpmn:sequenceFlow id="Flow_22" name="Tidak" sourceRef="Gateway_FinalApproval" targetRef="Activity_RevisiMenu" />
    <bpmn:sequenceFlow id="Flow_23" name="Ya" sourceRef="Gateway_FinalApproval" targetRef="Activity_PublishMenu" />
    <bpmn:sequenceFlow id="Flow_24" sourceRef="Activity_PublishMenu" targetRef="Activity_SendProductionPlan" />
    <bpmn:sequenceFlow id="Flow_25" sourceRef="Activity_SendProductionPlan" targetRef="Activity_ReceiveScheduleConfirm" />
    <bpmn:sequenceFlow id="Flow_26" sourceRef="Activity_ReceiveScheduleConfirm" targetRef="Activity_LockWeeklyPlan" />
    <bpmn:sequenceFlow id="Flow_27" sourceRef="Activity_LockWeeklyPlan" targetRef="Event_End" />

    <bpmn:dataStore id="DataStore_MenuMaster" name="Penyimpanan Menu Master" />
    <bpmn:dataStore id="DataStore_NutritionAI" name="Penyimpanan Gizi &amp; Rekomendasi AI" />
    <bpmn:dataStore id="DataStore_Stock" name="Penyimpanan Stok Bahan" />
    <bpmn:dataStore id="DataStore_Budget" name="Aturan HPP &amp; Budget" />
    <bpmn:dataStore id="DataStore_ApprovalHistory" name="Riwayat Persetujuan" />
    <bpmn:dataStore id="DataStore_WeeklyPlan" name="Weekly Plan Terpublikasi" />

    <bpmn:dataStoreReference id="DataStoreRef_MenuMaster" name="Menu Master" dataStoreRef="DataStore_MenuMaster" />
    <bpmn:dataStoreReference id="DataStoreRef_NutritionAI" name="Gizi &amp; AI" dataStoreRef="DataStore_NutritionAI" />
    <bpmn:dataStoreReference id="DataStoreRef_Stock" name="Stok Bahan" dataStoreRef="DataStore_Stock" />
    <bpmn:dataStoreReference id="DataStoreRef_Budget" name="Budget HPP" dataStoreRef="DataStore_Budget" />
    <bpmn:dataStoreReference id="DataStoreRef_ApprovalHistory" name="Riwayat Approval" dataStoreRef="DataStore_ApprovalHistory" />
    <bpmn:dataStoreReference id="DataStoreRef_WeeklyPlan" name="Weekly Plan" dataStoreRef="DataStore_WeeklyPlan" />

    <bpmn:association id="Association_01" sourceRef="Activity_SaveDraft" targetRef="DataStoreRef_MenuMaster" />
    <bpmn:association id="Association_02" sourceRef="Activity_AINutritionAnalysis" targetRef="DataStoreRef_NutritionAI" />
    <bpmn:association id="Association_03" sourceRef="Activity_CheckStock" targetRef="DataStoreRef_Stock" />
    <bpmn:association id="Association_04" sourceRef="Activity_HppCheck" targetRef="DataStoreRef_Budget" />
    <bpmn:association id="Association_05" sourceRef="Activity_FinanceReview" targetRef="DataStoreRef_ApprovalHistory" />
    <bpmn:association id="Association_06" sourceRef="Activity_PublishMenu" targetRef="DataStoreRef_MenuMaster" />
    <bpmn:association id="Association_07" sourceRef="Activity_LockWeeklyPlan" targetRef="DataStoreRef_WeeklyPlan" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_ToBeMenuPlanningAI">
    <bpmndi:BPMNPlane id="BPMNPlane_ToBeMenuPlanningAI" bpmnElement="Collaboration_ToBeMenuPlanningAI">
