      <bpmndi:BPMNShape id="DataStoreRef_NutritionAI_di" bpmnElement="DataStoreRef_NutritionAI">
        <dc:Bounds x="580" y="1030" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="DataStoreRef_Stock_di" bpmnElement="DataStoreRef_Stock">
        <dc:Bounds x="940" y="1030" width="50" height="50" />
